{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bunx prisma generate && bunx prisma migrate deploy && tsc --noEmit",
    "start": "bun run src/index.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:setup": "bunx prisma migrate deploy && bun run src/db/seed.ts",
    "seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai": "^1.2.0",
    "@prisma/client": "^6.6.0",
    "@tavily/core": "^0.7.3",
    "ai": "^4.2.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.6.0",
    "typescript": "^5.8.0"
  }
}
